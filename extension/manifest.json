{
  "manifest_version": 3,
  "name": "ReelKill — Shorts, Reels & FYP blocker",
  "short_name": "ReelKill",
  "description": "ReelKill removes Shorts, Reels, TikTok FYP, and stray 9:16 feeds on YouTube, Instagram, TikTok & Facebook — plus schedules & whitelists. Local-only. No accounts, no tracking.",
  "homepage_url": "https://focusshield-pro.pages.dev/",
  "version": "1.0.0",
  "minimum_chrome_version": "110",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "ReelKill",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*", "*://youtube.com/*"],
      "js": ["content/youtube.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.instagram.com/*", "*://instagram.com/*"],
      "js": ["content/instagram.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.tiktok.com/*", "*://tiktok.com/*"],
      "js": ["content/tiktok.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.facebook.com/*", "*://facebook.com/*"],
      "js": ["content/facebook.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "*://*.youtube.com/*",
        "*://*.instagram.com/*",
        "*://*.tiktok.com/*",
        "*://*.facebook.com/*"
      ],
      "js": ["content/universal.js"],
      "run_at": "document_idle"
    }
  ]
}
